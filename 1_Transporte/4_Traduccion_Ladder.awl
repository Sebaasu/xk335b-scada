Direction:BOOL;	// 0=reverse/1=forward  
END_VAR
VAR_OUTPUT
Done:BOOL;	// Function complete
END_VAR
VAR
Temp_DI:DINT;
Temp_R:REAL;
Temp_R2:REAL;
HSC_target_preset:DINT;
Actual_Stopping_Dist:DINT;
Max_Avail_Stop_Dist:DINT;
END_VAR
